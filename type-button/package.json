{
  "name": "normies-type-button",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "deploy:api": "wrangler deploy -c worker/wrangler.jsonc",
    "deploy:pages": "npm run build && wrangler pages deploy dist --project-name normies-type-button --commit-dirty=true",
    "deploy": "npm run deploy:api && npm run deploy:pages"
  },
  "dependencies": {
    "@fontsource/pixelify-sans": "^5.2.7",
    "@fontsource/vt323": "^5.2.7",
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}

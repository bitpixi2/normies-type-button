{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "normies-type-button-api",
  "main": "src/index.js",
  "compatibility_date": "2026-06-22",
  "workers_dev": true,
  "durable_objects": {
    "bindings": [
      {
        "name": "ARENA",
        "class_name": "ArenaObject"
      }
